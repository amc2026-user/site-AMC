{
  "redirects": [
    { "source": "/nous-contacter", "destination": "/contact", "permanent": true },
    { "source": "/prestations-motos", "destination": "/services", "permanent": true },
    { "source": "/prestations-autos", "destination": "/services", "permanent": true },
    { "source": "/nos-services", "destination": "/services", "permanent": true },
    { "source": "/on-parle-de-nous", "destination": "/about", "permanent": true },
    { "source": "/documentation", "destination": "/", "permanent": true },
    { "source": "/offre-en-cours", "destination": "/offres", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(site.webmanifest|robots.txt|sitemap.xml|llms.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!api|assets|icons|site.webmanifest|robots.txt|sitemap.xml|llms.txt|favicon.ico).*)", "destination": "/index.html" }
  ]
}
